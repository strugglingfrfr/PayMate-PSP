{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "../",
    "types": ["bun"],
    "paths": {
      "viem": ["./node_modules/viem"],
      "@chainlink/cre-sdk": ["./node_modules/@chainlink/cre-sdk"],
      "@chainlink/cre-sdk/*": ["./node_modules/@chainlink/cre-sdk/*"]
    }
  },
  "include": ["./**/*.ts", "../contracts/evm/ts/generated/Pool.ts", "../contracts/evm/ts/generated/YieldReserve.ts"],
  "exclude": ["node_modules", "dist", "../contracts/evm/ts/generated/index.ts", "../contracts/evm/ts/generated/*_mock.ts"]
}
